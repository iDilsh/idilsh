generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id        String   @id
  title     String
  excerpt   String   @default("")
  content   String   @default("")
  imageUrl  String?
  category  String   @default("Dharma")
  published Int      @default(0)
  createdAt String   @default("now()")
  updatedAt String   @default("now()")

  @@map("BlogPost")
}

model Video {
  id          String   @id
  title       String
  description String?
  youtubeId   String
  thumbnail   String?
  category    String   @default("Sermon")
  published   Int      @default(1)
  createdAt   String   @default("now()")
  updatedAt   String   @default("now()")

  @@map("Video")
}

model SiteSetting {
  id    String @id
  key   String @unique
  value String @default("")

  @@map("SiteSetting")
}
